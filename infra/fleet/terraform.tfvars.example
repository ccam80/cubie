# Copy to terraform.tfvars (gitignored) and fill in. Never commit the
# real file: license_key is a secret and the App key path points at a
# private key.

github_app_id               = 123456
github_app_private_key_path = "C:/Users/you/secrets/runs-on-fleet.private-key.pem"

# Same license as the existing RunsOn Flex CloudFormation install.
license_key = "ro-..."

alert_email = "you@example.com"

# Reuse the Flex stack's VPC (discover with:
#   aws cloudformation describe-stack-resources --stack-name runs-on \
#     --query "StackResources[?ResourceType=='AWS::EC2::VPC' || ResourceType=='AWS::EC2::Subnet']")
vpc_id            = "vpc-0123456789abcdef0"
public_subnet_ids = ["subnet-0123456789abcdef0", "subnet-0123456789abcdef1"]
